# =============================================================================
# ByteBrew Company Assistant -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Provider -----------------------------------------------------------

# Option 1: OpenAI (or any OpenAI-compatible API)
LLM_API_KEY=sk-your-openai-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# Option 2: Ollama (free, local)
# Uncomment these and comment out the lines above:
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3.2

# --- Admin Dashboard --------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# --- PostgreSQL (internal, no need to change) --------------------------------
POSTGRES_USER=bytebrew
POSTGRES_PASSWORD=bytebrew
POSTGRES_DB=bytebrew
