# LLM (OpenRouter)
LLM_API_KEY=sk-or-your-openrouter-key
LLM_MODEL=qwen/qwen3-coder-next
LLM_BASE_URL=https://openrouter.ai/api/v1

# Engine admin
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# BFF_JWT_SECRET signs end-user session cookies issued by the BFF service
# proxies (service-hr / service-support / service-sales). It is NOT used to
# authenticate to the engine — the engine manages its own Ed25519 keypair in
# local auth mode (BYTEBREW_AUTH_MODE=local, default).
# Generate with: openssl rand -hex 32
BFF_JWT_SECRET=your-random-32-byte-hex-secret

# Engine auth mode (local = engine self-generates Ed25519 keypair on first boot).
# For self-hosted/on-prem deployments leave this as 'local'.
BYTEBREW_AUTH_MODE=local

# Directory where the engine stores its Ed25519 keypair (auto-generated on first boot).
# Mount as a named volume to persist keys across container restarts.
BYTEBREW_JWT_KEYS_DIR=/var/lib/bytebrew/keys

# PostgreSQL
POSTGRES_PASSWORD=bytebrew
