# =============================================================================
# ByteBrew Sales Agent -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Provider -----------------------------------------------------------

# Option 1: OpenRouter (recommended -- access to many models)
LLM_API_KEY=sk-or-your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-coder-next

# Option 2: OpenAI
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Option 3: Ollama (free, local)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3.2

# --- Admin Dashboard --------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# --- Security ---------------------------------------------------------------
JWT_SECRET=example-jwt-secret

# --- PostgreSQL (internal, no need to change) --------------------------------
POSTGRES_USER=bytebrew
POSTGRES_PASSWORD=bytebrew
POSTGRES_DB=bytebrew
