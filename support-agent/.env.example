# =============================================================================
# ByteBrew Support Agent -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.

# --- LLM Provider -----------------------------------------------------------

# Option 1: OpenRouter (recommended -- access to many models)
LLM_API_KEY=sk-or-your-openrouter-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-coder-next

# Option 2: OpenAI
# LLM_API_KEY=sk-your-openai-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# Option 3: Ollama (free, local)
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=llama3.2

# --- Admin Dashboard --------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# --- Engine Auth (Ed25519, auto-generated on first boot) ---------------------
# Engine manages its own Ed25519 keypair under BYTEBREW_JWT_KEYS_DIR (mounted
# as a persistent volume). No secret to configure here.
BYTEBREW_AUTH_MODE=local
BYTEBREW_JWT_KEYS_DIR=/var/lib/bytebrew/keys

# --- BFF Session Tokens (only used when running the service/ proxy) ----------
# BFF_JWT_SECRET signs end-user session cookies issued by the optional BFF
# proxy in service/. It is NOT used to authenticate to the engine — the BFF
# forwards the admin-issued engine JWT in the upstream Authorization header.
# Generate with: openssl rand -hex 32
BFF_JWT_SECRET=example-bff-jwt-secret

# --- PostgreSQL (internal, no need to change) --------------------------------
POSTGRES_USER=bytebrew
POSTGRES_PASSWORD=bytebrew
POSTGRES_DB=bytebrew
